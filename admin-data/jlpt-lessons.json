{
  "lessons": [
    {
      "id": "jlpt-n5-tai",
      "level": "N5",
      "lessonNumber": 5,
      "titleJapanese": "〜たい",
      "titleMeaning": "Want to do",
      "mainExample": {
        "jp": "日本で美味しいラーメンを食べたいです。",
        "segments": [
          { "text": "日本", "reading": "にほん" },
          { "text": "で" },
          { "text": "美味しい", "reading": "おいしい" },
          { "text": "ラーメン" },
          { "text": "を" },
          { "text": "食べたい", "reading": "たべたい", "highlight": true },
          { "text": "です。" }
        ],
        "romaji": "Nihon de oishii ramen o tabetai desu.",
        "en": "I want to eat delicious ramen in Japan.",
        "audioText": "日本で美味しいラーメンを食べたいです。"
      },
      "structureFormula": [
        { "id": "verb", "text": "Verb (stem)", "kind": "chip" },
        { "id": "plus", "text": "+", "kind": "operator" },
        { "id": "tai", "text": "たい", "kind": "accent" }
      ],
      "conjugationChoices": [
        {
          "id": "taberu",
          "label": "食べる",
          "flow": [
            { "id": "dictionary", "label": "Dictionary", "value": "食べる" },
            { "id": "arrow-1", "label": "", "value": "↓" },
            { "id": "stem", "label": "Stem", "value": "食べ" },
            { "id": "arrow-2", "label": "", "value": "↓" },
            { "id": "base", "label": "Base", "value": "食べたい" },
            { "id": "arrow-3", "label": "", "value": "↓" },
            { "id": "result", "label": "Result", "value": "食べたいです", "emphasis": true }
          ]
        },
        {
          "id": "miru",
          "label": "見る",
          "flow": [
            { "id": "dictionary", "label": "Dictionary", "value": "見る" },
            { "id": "arrow-1", "label": "", "value": "↓" },
            { "id": "stem", "label": "Stem", "value": "見" },
            { "id": "arrow-2", "label": "", "value": "↓" },
            { "id": "base", "label": "Base", "value": "見たい" },
            { "id": "arrow-3", "label": "", "value": "↓" },
            { "id": "result", "label": "Result", "value": "見たいです", "emphasis": true }
          ]
        },
        {
          "id": "nomu",
          "label": "飲む",
          "flow": [
            { "id": "dictionary", "label": "Dictionary", "value": "飲む" },
            { "id": "arrow-1", "label": "", "value": "↓" },
            { "id": "stem", "label": "Stem", "value": "飲み" },
            { "id": "arrow-2", "label": "", "value": "↓" },
            { "id": "base", "label": "Base", "value": "飲みたい" },
            { "id": "arrow-3", "label": "", "value": "↓" },
            { "id": "result", "label": "Result", "value": "飲みたいです", "emphasis": true }
          ]
        }
      ],
      "nuances": [
        {
          "id": "desire",
          "title": "Personal desire",
          "description": "〜たい expresses what the speaker personally wants to do. It is most natural for your own wishes rather than someone else's internal desires.",
          "example": {
            "jp": "今日は早く帰りたいです。",
            "segments": [
              { "text": "今日", "reading": "きょう" },
              { "text": "は" },
              { "text": "早く", "reading": "はやく" },
              { "text": "帰りたい", "reading": "かえりたい", "highlight": true },
              { "text": "です。" }
            ],
            "romaji": "Kyou wa hayaku kaeritai desu.",
            "en": "I want to go home early today."
          }
        },
        {
          "id": "softness",
          "title": "Soft polite tone",
          "description": "Adding です after 〜たい makes the wish sound gentle and polite, especially in everyday conversation.",
          "example": {
            "jp": "新しい映画を見たいです。",
            "segments": [
              { "text": "新しい", "reading": "あたらしい" },
              { "text": "映画", "reading": "えいが" },
              { "text": "を" },
              { "text": "見たい", "reading": "みたい", "highlight": true },
              { "text": "です。" }
            ],
            "romaji": "Atarashii eiga o mitai desu.",
            "en": "I want to watch the new movie."
          }
        },
        {
          "id": "limits",
          "title": "Not for commands",
          "description": "〜たい talks about wanting to do something. It does not tell another person what to do, and it should not be used as an imperative."
        }
      ],
      "examples": [
        {
          "jp": "週末に友だちと買い物したいです。",
          "segments": [
            { "text": "週末", "reading": "しゅうまつ" },
            { "text": "に" },
            { "text": "友だち", "reading": "ともだち" },
            { "text": "と" },
            { "text": "買い物", "reading": "かいもの" },
            { "text": "したい", "reading": "したい", "highlight": true },
            { "text": "です。" }
          ],
          "romaji": "Shuumatsu ni tomodachi to kaimono shitai desu.",
          "en": "I want to go shopping with my friend this weekend."
        },
        {
          "jp": "来年は北海道へ行きたいです。",
          "segments": [
            { "text": "来年", "reading": "らいねん" },
            { "text": "は" },
            { "text": "北海道", "reading": "ほっかいどう" },
            { "text": "へ" },
            { "text": "行きたい", "reading": "いきたい", "highlight": true },
            { "text": "です。" }
          ],
          "romaji": "Rainen wa Hokkaidou e ikitai desu.",
          "en": "I want to go to Hokkaido next year."
        },
        {
          "jp": "今日は静かなカフェで勉強したいです。",
          "segments": [
            { "text": "今日", "reading": "きょう" },
            { "text": "は" },
            { "text": "静かな", "reading": "しずかな" },
            { "text": "カフェ" },
            { "text": "で" },
            { "text": "勉強", "reading": "べんきょう" },
            { "text": "したい", "reading": "したい", "highlight": true },
            { "text": "です。" }
          ],
          "romaji": "Kyou wa shizuka na kafe de benkyou shitai desu.",
          "en": "I want to study at a quiet cafe today."
        }
      ]
    },
    {
      "id": "jlpt-n4-nagara",
      "level": "N4",
      "lessonNumber": 18,
      "titleJapanese": "〜ながら",
      "titleMeaning": "While doing / At the same time as",
      "mainExample": {
        "jp": "音楽を聞きながら宿題をします。",
        "segments": [
          { "text": "音楽", "reading": "おんがく" },
          { "text": "を" },
          { "text": "聞きながら", "reading": "ききながら", "highlight": true },
          { "text": "宿題", "reading": "しゅくだい" },
          { "text": "を" },
          { "text": "します。" }
        ],
        "romaji": "Ongaku o kikinagara shukudai o shimasu.",
        "en": "I do my homework while listening to music.",
        "audioText": "音楽を聞きながら宿題をします。"
      },
      "structureFormula": [
        { "id": "verb", "text": "Verb (stem)", "kind": "chip" },
        { "id": "plus", "text": "+", "kind": "operator" },
        { "id": "nagara", "text": "ながら", "kind": "accent" }
      ],
      "conjugationChoices": [
        {
          "id": "kiku",
          "label": "聞く",
          "flow": [
            { "id": "dictionary", "label": "Dictionary", "value": "聞く" },
            { "id": "arrow-1", "label": "", "value": "↓" },
            { "id": "stem", "label": "Stem", "value": "聞き" },
            { "id": "arrow-2", "label": "", "value": "↓" },
            { "id": "base", "label": "Base", "value": "聞きながら" },
            { "id": "arrow-3", "label": "", "value": "↓" },
            { "id": "result", "label": "Result", "value": "聞きながら宿題をします", "emphasis": true }
          ]
        },
        {
          "id": "aruku",
          "label": "歩く",
          "flow": [
            { "id": "dictionary", "label": "Dictionary", "value": "歩く" },
            { "id": "arrow-1", "label": "", "value": "↓" },
            { "id": "stem", "label": "Stem", "value": "歩き" },
            { "id": "arrow-2", "label": "", "value": "↓" },
            { "id": "base", "label": "Base", "value": "歩きながら" },
            { "id": "arrow-3", "label": "", "value": "↓" },
            { "id": "result", "label": "Result", "value": "歩きながら話します", "emphasis": true }
          ]
        },
        {
          "id": "taberu",
          "label": "食べる",
          "flow": [
            { "id": "dictionary", "label": "Dictionary", "value": "食べる" },
            { "id": "arrow-1", "label": "", "value": "↓" },
            { "id": "stem", "label": "Stem", "value": "食べ" },
            { "id": "arrow-2", "label": "", "value": "↓" },
            { "id": "base", "label": "Base", "value": "食べながら" },
            { "id": "arrow-3", "label": "", "value": "↓" },
            { "id": "result", "label": "Result", "value": "食べながら読みます", "emphasis": true }
          ]
        }
      ],
      "nuances": [
        {
          "id": "same-subject",
          "title": "Same subject",
          "description": "The person doing both actions is usually the same. 〜ながら links two actions performed by one subject."
        },
        {
          "id": "main-action",
          "title": "Second action feels main",
          "description": "The action after 〜ながら often feels like the main action, while the first action forms the background.",
          "example": {
            "jp": "コーヒーを飲みながら本を読みます。",
            "segments": [
              { "text": "コーヒー" },
              { "text": "を" },
              { "text": "飲みながら", "reading": "のみながら", "highlight": true },
              { "text": "本", "reading": "ほん" },
              { "text": "を" },
              { "text": "読みます", "reading": "よみます" }
            ],
            "romaji": "Koohii o nominagara hon o yomimasu.",
            "en": "I read a book while drinking coffee."
          }
        },
        {
          "id": "limited-simultaneity",
          "title": "Natural simultaneity",
          "description": "Use it when the two actions can naturally happen together. If the pairing feels impossible or forced, another structure may be better."
        }
      ],
      "examples": [
        {
          "jp": "電車に乗りながらニュースを読みました。",
          "segments": [
            { "text": "電車", "reading": "でんしゃ" },
            { "text": "に" },
            { "text": "乗りながら", "reading": "のりながら", "highlight": true },
            { "text": "ニュース" },
            { "text": "を" },
            { "text": "読みました", "reading": "よみました" }
          ],
          "romaji": "Densha ni norinagara nyuusu o yomimashita.",
          "en": "I read the news while riding the train."
        },
        {
          "jp": "彼は笑いながら答えました。",
          "segments": [
            { "text": "彼", "reading": "かれ" },
            { "text": "は" },
            { "text": "笑いながら", "reading": "わらいながら", "highlight": true },
            { "text": "答えました", "reading": "こたえました" }
          ],
          "romaji": "Kare wa warainagara kotaemashita.",
          "en": "He answered while smiling."
        },
        {
          "jp": "私は歩きながら日本語のポッドキャストを聞きます。",
          "segments": [
            { "text": "私", "reading": "わたし" },
            { "text": "は" },
            { "text": "歩きながら", "reading": "あるきながら", "highlight": true },
            { "text": "日本語", "reading": "にほんご" },
            { "text": "の" },
            { "text": "ポッドキャスト" },
            { "text": "を" },
            { "text": "聞きます", "reading": "ききます" }
          ],
          "romaji": "Watashi wa arukinagara nihongo no poddokyasuto o kikimasu.",
          "en": "I listen to Japanese podcasts while walking."
        }
      ]
    },
    {
