            { "text": "電車", "reading": "でんしゃ" },
            { "text": "に" },
            { "text": "置いてしまった", "reading": "おいてしまった", "highlight": true },
            { "text": "。" }
          ],
          "romaji": "Kasa o densha ni oite shimatta.",
          "en": "I left my umbrella on the train (by accident)."
        },
        {
          "jp": "その秘密を友だちに話してしまった。",
          "segments": [
