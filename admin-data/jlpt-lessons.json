            { "text": "秘密", "reading": "ひみつ" },
            { "text": "を" },
            { "text": "友だち", "reading": "ともだち" },
            { "text": "に" },
            { "text": "話してしまった", "reading": "はなしてしまった", "highlight": true },
            { "text": "。" }
          ],
          "romaji": "Sono himitsu o tomodachi ni hanashite shimatta.",
          "en": "I ended up telling my friend that secret."
        }
      ]
    },
    {
      "id": "jlpt-n2-wakedehanai",
      "level": "N2",
      "lessonNumber": 17,
      "titleJapanese": "〜わけではない",
      "titleMeaning": "It is not that / It does not mean that",
      "mainExample": {
