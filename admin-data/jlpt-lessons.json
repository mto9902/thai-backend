          "label": "言う",
          "flow": [
            { "id": "dictionary", "label": "Dictionary", "value": "言う" },
            { "id": "arrow-1", "label": "", "value": "↓" },
            { "id": "te-form", "label": "Te-form", "value": "言って" },
            { "id": "arrow-2", "label": "", "value": "↓" },
            { "id": "base", "label": "Base", "value": "言ってしまう" },
            { "id": "arrow-3", "label": "", "value": "↓" },
            { "id": "result", "label": "Result", "value": "言ってしまった", "emphasis": true }
          ]
        },
        {
